<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="MedQueue — Professional Clinic Appointment Management with smart patient triage, doctor booking, and priority queue management.">
  <title><%= title %></title>

  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏥</text></svg>">
  <script src="https://unpkg.com/lucide@latest"></script>

  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages.css">
</head>
<body>

  <div class="app-container">

    <!-- ══════ SIDEBAR ══════ -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        <div class="brand-icon">🏥</div>
        <div class="brand-name">Med<span>Queue</span></div>
      </div>

      <div class="sidebar-section-label">Main Menu</div>
      <nav class="sidebar-nav">
        <a href="#dashboard" class="nav-item active" data-page="dashboard">
          <i data-lucide="layout-dashboard"></i>
          <span>Dashboard</span>
        </a>
        <a href="#register" class="nav-item" data-page="register">
          <i data-lucide="user-plus"></i>
          <span>Register Patient</span>
        </a>
        <a href="#queue" class="nav-item" data-page="queue">
          <i data-lucide="list-ordered"></i>
          <span>Appointment Queue</span>
        </a>
        <a href="#doctors" class="nav-item" data-page="doctors">
          <i data-lucide="stethoscope"></i>
          <span>Doctors</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="server-status">
          <span class="status-dot"></span>
          <span>Server Online</span>
        </div>
        <p>© 2026 MedQueue</p>
        <p>Clinic Management v1.0</p>
      </div>
    </aside>

    <!-- ══════ MOBILE NAV ══════ -->
    <nav class="mobile-nav">
      <a href="#dashboard" class="nav-item active" data-page="dashboard">
        <i data-lucide="layout-dashboard"></i><span>Home</span>
      </a>
      <a href="#register" class="nav-item" data-page="register">
        <i data-lucide="user-plus"></i><span>Register</span>
      </a>
      <a href="#queue" class="nav-item" data-page="queue">
        <i data-lucide="list-ordered"></i><span>Queue</span>
      </a>
      <a href="#doctors" class="nav-item" data-page="doctors">
        <i data-lucide="stethoscope"></i><span>Doctors</span>
      </a>
    </nav>

    <!-- ══════ MAIN CONTENT ══════ -->
    <main class="main-content">

      <div class="disclaimer-banner">
        <i data-lucide="alert-triangle" style="width:16px;height:16px;flex-shrink:0"></i>
        <span><strong>Disclaimer:</strong> This is a demonstration system. Symptom triage is keyword-based and should never replace professional medical advice.</span>
      </div>

      <!-- ═══ DASHBOARD ═══ -->
      <div id="page-dashboard" class="page active">
        <!-- Greeting -->
        <div class="greeting-section">
          <div class="greeting-text">
            <h1 id="greetingTitle">Good Morning 👋</h1>
            <p>Here's an overview of your clinic's activity today.</p>
          </div>
          <div class="greeting-actions">
            <div class="greeting-date" id="currentDate">
              <i data-lucide="calendar" style="width:14px;height:14px"></i>
              <span>Loading...</span>
            </div>
            <button class="btn btn-primary btn-sm" onclick="App.navigateTo('register')">
              <i data-lucide="plus" style="width:14px;height:14px"></i> New Patient
            </button>
          </div>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
          <div class="stat-card animate-fade-up stagger-1">
            <div class="stat-card-header">
              <div class="stat-icon accent"><i data-lucide="users" style="width:20px;height:20px"></i></div>
              <span class="stat-trend up">↑ Active</span>
            </div>
            <div class="stat-value" id="statPatients">—</div>
            <div class="stat-label">Total Patients</div>
            <div class="stat-bar accent"></div>
          </div>
          <div class="stat-card animate-fade-up stagger-2">
            <div class="stat-card-header">
              <div class="stat-icon info"><i data-lucide="calendar-check" style="width:20px;height:20px"></i></div>
              <span class="stat-trend neutral">Today</span>
            </div>
            <div class="stat-value" id="statToday">—</div>
            <div class="stat-label">Today's Appointments</div>
            <div class="stat-bar normal"></div>
          </div>
          <div class="stat-card animate-fade-up stagger-3">
            <div class="stat-card-header">
              <div class="stat-icon critical"><i data-lucide="alert-circle" style="width:20px;height:20px"></i></div>
              <span class="stat-trend down">Urgent</span>
            </div>
            <div class="stat-value" id="statCritical">—</div>
            <div class="stat-label">Critical Cases</div>
            <div class="stat-bar critical"></div>
          </div>
          <div class="stat-card animate-fade-up stagger-4">
            <div class="stat-card-header">
              <div class="stat-icon warning"><i data-lucide="heart-pulse" style="width:20px;height:20px"></i></div>
              <span class="stat-trend up">Online</span>
            </div>
            <div class="stat-value" id="statDoctors">—</div>
            <div class="stat-label">Available Doctors</div>
            <div class="stat-bar warning"></div>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="section-header">
          <div>
            <h2 class="section-title">Quick Actions</h2>
            <p class="section-subtitle">Common tasks at a glance</p>
          </div>
        </div>
        <div class="quick-actions">
          <a class="quick-action-card" onclick="App.navigateTo('register')">
            <div class="quick-action-icon" style="background:var(--accent-light);color:var(--accent)">
              <i data-lucide="user-plus" style="width:18px;height:18px"></i>
            </div>
            <div>
              <div class="quick-action-label">Register Patient</div>
              <div class="quick-action-sublabel">New patient intake</div>
            </div>
          </a>
          <a class="quick-action-card" onclick="App.navigateTo('queue')">
            <div class="quick-action-icon" style="background:var(--info-bg);color:var(--info)">
              <i data-lucide="clipboard-list" style="width:18px;height:18px"></i>
            </div>
            <div>
              <div class="quick-action-label">View Queue</div>
              <div class="quick-action-sublabel">Priority appointments</div>
            </div>
          </a>
          <a class="quick-action-card" onclick="App.navigateTo('doctors')">
            <div class="quick-action-icon" style="background:var(--warning-bg);color:var(--warning)">
              <i data-lucide="stethoscope" style="width:18px;height:18px"></i>
            </div>
            <div>
              <div class="quick-action-label">Manage Doctors</div>
              <div class="quick-action-sublabel">Leaves & availability</div>
            </div>
          </a>
        </div>

        <!-- Dashboard Grid: Table + Activity -->
        <div class="dashboard-grid">
          <div>
            <div class="section-header">
              <div>
                <h2 class="section-title">Recent Appointments</h2>
                <p class="section-subtitle">Latest bookings across all clinics</p>
              </div>
            </div>
            <div class="table-wrapper">
              <table class="recent-table">
                <thead>
                  <tr>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Hospital</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Severity</th>
                  </tr>
                </thead>
                <tbody id="recentBody">
                  <tr><td colspan="6" class="empty-state">Loading...</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Activity Panel -->
          <div class="activity-panel">
            <div class="activity-panel-header">
              <h3 class="activity-panel-title">Activity</h3>
              <span class="badge badge-info">Live</span>
            </div>
            <div class="activity-list" id="activityList">
              <div class="loading-state" style="padding:var(--space-xl)">
                <div class="spinner"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ REGISTER PATIENT ═══ -->
      <div id="page-register" class="page">
        <div class="page-header">
          <h1 class="page-title">Register Patient</h1>
          <p class="page-description">Enter patient details and symptoms for smart server-side triage assessment.</p>
        </div>
        <div class="register-form">
          <div class="glass-card-static">
            <form id="registerForm" autocomplete="off">
              <div class="form-grid">
                <div class="form-group">
                  <label class="form-label" for="patientName">Full Name</label>
                  <input type="text" class="form-input" id="patientName" placeholder="e.g. Rajesh Kumar" required>
                </div>
                <div class="form-group">
                  <label class="form-label" for="patientPhone">Contact Number</label>
                  <input type="tel" class="form-input" id="patientPhone" placeholder="e.g. +91 98765 43210" required>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label" for="patientAddress">Address</label>
                <input type="text" class="form-input" id="patientAddress" placeholder="e.g. 123 Main Street, City" required>
              </div>
              <div class="form-group">
                <label class="form-label" for="patientSymptoms">Describe Symptoms</label>
                <textarea class="form-textarea form-input" id="patientSymptoms" rows="4" placeholder="Describe all symptoms in detail, e.g. 'severe chest pain, difficulty breathing, dizziness for 2 hours'" required></textarea>
                <p class="form-hint">💡 Be descriptive — our triage engine scans for keywords like "chest pain", "fever", "headache", "fracture", etc.</p>
              </div>
              <button type="submit" class="btn btn-primary btn-lg" id="registerBtn">
                <i data-lucide="scan-search" style="width:18px;height:18px"></i>
                Analyze & Register
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- ═══ TRIAGE RESULTS ═══ -->
      <div id="page-triage" class="page">
        <div class="page-header">
          <h1 class="page-title">Triage Assessment <span class="page-badge">Server-Powered</span></h1>
          <p class="page-description">Symptom analysis and hospital recommendations.</p>
        </div>
        <div class="triage-container">
          <div id="triageResultArea"></div>
          <div class="section-header">
            <div>
              <h2 class="section-title">Suggested Specialties</h2>
              <p class="section-subtitle">Based on the reported symptoms</p>
            </div>
          </div>
          <div id="suggestedSpecialties" style="display:flex;flex-wrap:wrap;gap:var(--space-sm);margin-bottom:var(--space-3xl)"></div>
          <div class="section-header">
            <div>
              <h2 class="section-title">Recommended Hospitals</h2>
              <p class="section-subtitle">Sorted by specialty match and rating</p>
            </div>
          </div>
          <div id="hospitalRecommendations" class="cards-grid"></div>
        </div>
      </div>

      <!-- ═══ BOOKING FLOW ═══ -->
      <div id="page-booking" class="page">
        <div class="page-header">
          <h1 class="page-title">Book Appointment</h1>
          <p class="page-description">at <strong id="bookingHospitalName"></strong></p>
        </div>
        <div class="booking-steps">
          <div class="step active"><div class="step-number">1</div><span>Select Doctor</span></div>
          <div class="step-connector"></div>
          <div class="step"><div class="step-number">2</div><span>Pick Date</span></div>
          <div class="step-connector"></div>
          <div class="step"><div class="step-number">3</div><span>Choose Slot</span></div>
        </div>
        <div class="section-header">
          <div><h2 class="section-title">Available Doctors</h2><p class="section-subtitle">Recommended doctors are highlighted</p></div>
        </div>
        <div id="doctorsList" class="cards-grid" style="margin-bottom:var(--space-3xl)"></div>
        <div id="datePickerArea" style="display:none;margin-bottom:var(--space-3xl)"></div>
        <div id="timeSlotsArea" style="display:none;margin-bottom:var(--space-3xl)"></div>
        <div id="confirmArea" style="display:none"></div>
      </div>

      <!-- ═══ APPOINTMENT QUEUE ═══ -->
      <div id="page-queue" class="page">
        <div class="page-header page-header-row">
          <div>
            <h1 class="page-title">Appointment Queue</h1>
            <p class="page-description">Priority-ordered — critical patients are served first.</p>
          </div>
          <div class="filter-tabs" id="queueFilters">
            <button class="filter-tab active" data-filter="all" onclick="QueueManager.filter('all')">All</button>
            <button class="filter-tab" data-filter="critical" onclick="QueueManager.filter('critical')">Critical</button>
            <button class="filter-tab" data-filter="normal" onclick="QueueManager.filter('normal')">Normal</button>
          </div>
        </div>
        <div id="queueContainer">
          <div class="loading-state"><div class="spinner"></div><p>Loading queue...</p></div>
        </div>
      </div>

      <!-- ═══ DOCTOR MANAGEMENT ═══ -->
      <div id="page-doctors" class="page">
        <div class="page-header page-header-row">
          <div>
            <h1 class="page-title">Doctor Management</h1>
            <p class="page-description">View all doctors, availability status, and manage leaves.</p>
          </div>
          <div class="search-bar">
            <i data-lucide="search" class="search-icon" style="width:16px;height:16px"></i>
            <input type="text" class="form-input" id="doctorSearch" placeholder="Search doctors..." oninput="DoctorManagement.search(this.value)">
          </div>
        </div>
        <div id="doctorsContainer">
          <div class="loading-state"><div class="spinner"></div><p>Loading doctors...</p></div>
        </div>
      </div>

    </main>
  </div>

  <!-- ══════ MODAL ══════ -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title" id="modalTitle"></h3>
        <button class="modal-close" id="modalCloseBtn" aria-label="Close modal">✕</button>
      </div>
      <div class="modal-body" id="modalBody"></div>
      <div class="modal-footer" id="modalFooter"></div>
    </div>
  </div>

  <!-- ══════ TOASTS ══════ -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- ══════ SCRIPTS ══════ -->
  <script src="/js/api.js"></script>
  <script src="/js/utils.js"></script>
  <script src="/js/app.js"></script>

</body>
</html>
